SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret
GITHUB_TOKEN=ghp-your-github-token
DEFAULT_GITHUB_REPO=owner/repo
GOOGLE_API_KEY=your-google-api-key
LLAMA_BASE_URL=http://localhost:8080

# MCP Server Configuration (MCP primary, direct API as fallback)
MCP_GITHUB_ENABLED=true
MCP_FETCH_ENABLED=true
MCP_SLACK_ENABLED=true

# Max Slack messages used as context when summarizing (warn if exceeded)
SLACK_SUMMARY_MAX_MESSAGES=25
